
# Your user phone number (include country code, e.g. +12025551234)
PHONE=

# Your app_id and api_hash obtained from my.telegram.org/apps
API_ID=
API_HASH=

# Chat ID of Source chat and Destination chat (optional built-in route)
SOURCE=
DESTINATION=

# An arbitrary encryption key for the local TDLib database.
# Generate a strong random value and keep it secret.
DB_PASSWORD=

# Optional management Bot (private-chat commands for authorized admins only).
# Create a Bot via @BotFather, then paste the token here.
BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to run Bot commands in private chat.
# Do NOT use brackets, quotes, or JSON — plain integers only.
# Single admin:   BOT_ADMIN_IDS=123456789
# Multiple admins: BOT_ADMIN_IDS=123456789,987654321
# Spaces after commas are OK: BOT_ADMIN_IDS=123456789, 987654321
# Find your user ID via @userinfobot or @getidsbot in Telegram.
BOT_ADMIN_IDS=

# Where the app stores downloaded media files (default: data/tdlib_files)
FILES_DIRECTORY=data/tdlib_files

# Whether to strip the "Forwarded from" attribution header when copying (default: true)
# Set to false to preserve the original forwarding attribution.
SEND_COPY=true

# Proxy (optional). Used by TDLib and the management Bot for Telegram API access.
# Use URL encoding for special characters in username/password.
# Example: socks5://user:pass@192.168.0.2:7891
PROXY_URL=
